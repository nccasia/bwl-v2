{
  "name": "@bwl/server",
  "description": "BWL - Next Generation of Meme Social Media Platform - Server",
  "version": "1.0.0",
  "private": false,
  "scripts": {
    "start": "node dist/main.js",
    "dev": "nest start --watch",
    "build": "nest build",
    "build:prod": "node dist/main.js",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:run": "npm run build && typeorm migration:run -d ./dist/type-orm.config.js",
    "migration:generate": "npm run build && typeorm migration:generate -d ./dist/type-orm.config.js",
    "migration:revert": "npm run build && typeorm migration:revert -d ./dist/type-orm.config.js",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.808.0",
    "@aws-sdk/s3-request-presigner": "^3.808.0",
    "@bull-board/api": "^6.20.6",
    "@bull-board/express": "^6.20.6",
    "@bull-board/nestjs": "^6.20.6",
    "@nestjs-modules/ioredis": "^2.0.2",
    "@nestjs/axios": "^3.1.3",
    "@nestjs/bullmq": "^11.0.2",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.0.6",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/swagger": "^7.3.1",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.4.15",
    "@react-email/components": "^0.5.3",
    "@react-email/render": "^1.2.3",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.56.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "express-basic-auth": "^1.2.1",
    "form-data": "^4.0.3",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.2",
    "otp-agent": "^3.3.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "randomstring": "^1.3.1",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.1.0",
    "rxjs": "^7.8.1",
    "slug": "8.2.3",
    "typeorm": "^0.3.20",
    "typeorm-naming-strategies": "^4.1.0",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.8",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.15",
    "@types/node": "^22.10.7",
    "@types/randomstring": "^1.3.0",
    "@types/slug": "^5.0.9",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^@base/(.*)$": "<rootDir>/base/$1",
      "^@constants$": "<rootDir>/constants",
      "^@enums/(.*)$": "<rootDir>/enums/$1",
      "^@configs/(.*)$": "<rootDir>/configs/$1",
      "^@modules/(.*)$": "<rootDir>/modules/$1"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/../test/setup.ts"
    ]
  }
}
