{
  "name": "server",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/server/src",
  "projectType": "application",
  "tags": ["type:app", "scope:server"],
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/server",
        "main": "apps/server/src/main.ts",
        "tsConfig": "apps/server/tsconfig.json",
        "webpackConfig": "apps/server/webpack.config.js"
      },
      "configurations": {
        "development": {
          "optimization": false,
          "sourceMap": true
        },
        "production": {
          "optimization": true,
          "sourceMap": false
        }
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "server:build",
        "watch": true
      },
      "configurations": {
        "development": {
          "buildTarget": "server:build:development"
        },
        "production": {
          "buildTarget": "server:build:production"
        }
      }
    },
    "migration:run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run build && pnpm typeorm migration:run -d ./dist/type-orm.config.js",
        "cwd": "apps/server"
      }
    },
    "migration:generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run build && pnpm typeorm migration:generate -d ./dist/type-orm.config.js",
        "cwd": "apps/server"
      }
    },
    "migration:revert": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run build && pnpm typeorm migration:revert -d ./dist/type-orm.config.js",
        "cwd": "apps/server"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/apps/server"],
      "options": {
        "jestConfig": "apps/server/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/server/**/*.{ts,js}"]
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["tsc --noEmit"],
        "cwd": "apps/server"
      }
    }
  }
}
