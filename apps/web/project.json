{
  "name": "web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/web/src",
  "projectType": "application",
  "tags": ["type:app", "scope:web"],
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/web",
        "root": "apps/web",
        "fileName": "static/chunks/app-page.js",
        "nextConfig": "apps/web/next.config.ts",
        "tsConfig": "apps/web/tsconfig.json"
      },
      "configurations": {
        "development": {
          "dev": true
        },
        "production": {
          "optimization": true
        }
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm next dev",
        "cwd": "apps/web",
        "envFile": ""
      }
    },
    "serve:production": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm next start",
        "cwd": "apps/web"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "apps/web"
      },
      "outputs": ["{workspaceRoot}/coverage/apps/web"]
    },
    "test:watch": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest",
        "cwd": "apps/web"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/web/src/**/*.{ts,tsx,js,jsx}"]
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["tsc --noEmit"],
        "cwd": "apps/web"
      }
    }
  }
}
