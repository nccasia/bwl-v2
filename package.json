{
  "name": "bwl-vn",
  "description": "BWL - Next Generation of Meme Social Media Platform",
  "version": "1.0.0",
  "private": false,
  "license": "MIT",
  "scripts": {
    "dev": "nx run-many --target=serve --parallel=2",
    "dev:web": "nx serve web --configuration=development",
    "dev:server": "nx serve server --configuration=development",
    "build": "nx run-many --target=build",
    "build:web": "nx build web --configuration=production",
    "build:server": "nx build server --configuration=production",
    "start:web": "nx run web:serve:production",
    "start:server": "nx serve server --configuration=production",
    "migration:run": "nx run server:migration:run",
    "migration:generate": "nx run server:migration:generate",
    "migration:revert": "nx run server:migration:revert",
    "test": "nx run-many --target=test",
    "test:web": "nx run web:test",
    "test:web:watch": "nx run web:test:watch",
    "test:server": "nx run server:test",
    "lint": "nx run-many --target=lint",
    "lint:web": "nx lint web",
    "lint:server": "nx lint server",
    "type-check": "nx run-many --target=type-check",
    "clean": "rm -rf dist .nx coverage",
    "format": "prettier --write \"{apps,libs}/**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"{apps,libs}/**/*.{ts,tsx,js,json,md}\"",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@babel/preset-env": "^7.26.9",
    "@babel/preset-react": "^7.26.3",
    "@babel/preset-typescript": "^7.26.0",
    "@nx/eslint": "22.6.1",
    "@nx/eslint-plugin": "22.6.1",
    "@nx/jest": "22.6.1",
    "@nx/js": "22.6.1",
    "@nx/next": "22.6.1",
    "@nx/node": "22.6.1",
    "@nx/webpack": "22.6.1",
    "@nx/workspace": "22.6.1",
    "@types/babel__core": "^7.20.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "autoprefixer": "^10.4.20",
    "babel-loader": "^9.2.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "next": "^15.0.0",
    "nx": "22.6.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.6",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@internationalized/date": "^3.12.0",
    "axios": "^1.13.6",
    "dayjs": "^1.11.20",
    "js-base64": "^3.7.8",
    "lodash": "^4.17.23",
    "query-string": "^7.1.3",
    "react-stately": "^3.45.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@swc/core",
      "sharp"
    ]
  },
  "packageManager": "pnpm@10.18.2+sha512.9fb969fa749b3ade6035e0f109f0b8a60b5d08a1a87fdf72e337da90dcc93336e2280ca4e44f2358a649b83c17959e9993e777c2080879f3801e6f0d999ad3dd"
}